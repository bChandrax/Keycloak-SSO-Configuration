{
  "realm": "myapp-frontend",
  "enabled": true,
  "displayName": "MyApp Frontend",
  "loginTheme": "keywind",

  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "verifyEmail": false,

  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyLookAheadWindow": 1,

  "clients": [
    {
      "clientId": "myapp-frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5173",
        "http://localhost:4173/*",
        "http://localhost:4173",
        "http://localhost:3000/*",
        "http://localhost:3000"
      ],
      "webOrigins": ["*"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],

  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${env.GOOGLE_CLIENT_ID}",
        "clientSecret": "${env.GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid profile email",
        "syncMode": "IMPORT"
      }
    }
  ]
}